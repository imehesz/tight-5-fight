.godot/
*.import
export.cfg
export_presets.cfg
# ignore build OUTPUT but keep .gdignore tracked: build/ lives inside the Godot
# project, so without it the editor imports the last export's index.png and the
# next export packs it back into the .pck (~3.5MB of compounding bloat).
build/*
!build/.gdignore
deployScriptPROD.sh
rsync_exclude.txt

# multiplayer server
server/node_modules/
server/data/
server/config.dev.js
server/config.prod.js
server/config.qa.js
deployScriptPRODBE.sh
deployScriptPRODWEB.sh
deploy-be/
*.Identifier
tools/*
helper-tools/.cache/
helper-tools/__pycache__/

requirements/
build/
